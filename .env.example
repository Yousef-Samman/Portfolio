# API server (default 3001)
PORT=3001

# Public site URL when deployed
APP_URL=http://localhost:3000

# Production only (Vercel): URL of your Render API — no trailing slash
# Leave empty for local dev (Vite proxies /api to port 3001)
# VITE_API_URL=https://your-api.onrender.com

# Optional: restrict CORS in production (default *)
# CORS_ORIGIN=https://yourdomain.com

# CV filename under public/cv/
CV_FILENAME=YousefCv.pdf

# Contact form limits
# Minimum minutes between two messages (same IP or same email address)
CONTACT_COOLDOWN_MINUTES=15
# Max submissions per IP per rolling hour (after cooldown rules)
CONTACT_RATE_LIMIT_PER_HOUR=8

# Cloudflare Turnstile CAPTCHA (https://dash.cloudflare.com → Turnstile)
# Site key is public (frontend); secret stays server-only
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# --- Email notifications (server only — never in frontend code) ---

# Your private inbox (Gmail) — receives form alerts
CONTACT_NOTIFY_EMAIL=your-private-email@gmail.com

# Max notification emails per 24 hours (anti-spam)
CONTACT_EMAIL_DAILY_CAP=30

# Option A: Gmail SMTP (recommended for personal inbox)
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-private-email@gmail.com
SMTP_PASS=your-16-char-app-password

# Option B: Resend (https://resend.com) — use instead of SMTP if you prefer
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_EMAIL_FROM=Portfolio <onboarding@resend.dev>

# Optional: Plausible analytics
# VITE_PLAUSIBLE_DOMAIN=yourdomain.com
